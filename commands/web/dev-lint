#!/bin/bash

## #ddev-generated
## Description: Run all linting tools on changed custom modules and themes files
# Fail on:
# -u : undefined variables
# -o pipefail : failure in a pipeline propagates
# Usage: ddev dev-lint
#        In CI environment: Uses predefined changed files
#        In local environment: Uses git diff to detect changes

set -uo pipefail

# Track overall linting status
LINT_STATUS=0

echo "🔍 Running linters..."

if [ "${IS_CI:-false}" = "TRUE" ]; then
    echo "📋 Running in CI environment - using predefined changed files"

    # Run each tool with predefined files if available
    if [ -n "${PHP_CHANGED_FILES:-}" ]; then
        echo "➡ PHP Linting..."
        echo "$PHP_CHANGED_FILES" | tr ' ' '\n'
        if ! .ddev/commands/web/dev-phpcs --files="$PHP_CHANGED_FILES"; then
            LINT_STATUS=1
        fi
    else
        echo "✅ Skipping PHP lint"
    fi

    if [ -n "${PHP_CHANGED_FILES:-}" ]; then
        echo "➡ PHP Static Analysis..."
        echo "$PHP_CHANGED_FILES" | tr ' ' '\n'
        if ! .ddev/commands/web/dev-phpstan --files="$PHP_CHANGED_FILES"; then
            LINT_STATUS=1
        fi
    else
        echo "✅ Skipping PHP static analysis"
    fi

    #if [ -n "${SECURITY_CHANGED_FILES:-}" ]; then
    #    echo "➡ Drupal Security PHPCS..."
    #    echo "$SECURITY_CHANGED_FILES" | tr ' ' '\n'
    #    if ! .ddev/commands/web/dev-phpcs-security --files="$SECURITY_CHANGED_FILES"; then
    #        LINT_STATUS=1
    #    fi
    #else
    #    echo "✅ Skipping Drupal Security PHPCS"
    #fi

    if [ -n "${JS_CHANGED_FILES:-}" ]; then
        echo "➡ JS Linting..."
        echo "$JS_CHANGED_FILES" | tr ' ' '\n'
        if ! .ddev/commands/web/dev-eslint --files="$JS_CHANGED_FILES"; then
            LINT_STATUS=1
        fi
    else
        echo "✅ Skipping JS lint"
    fi

    if [ -n "${STYLE_CHANGED_FILES:-}" ]; then
        echo "➡ CSS Linting..."
        echo "$STYLE_CHANGED_FILES" | tr ' ' '\n'
        if ! .ddev/commands/web/dev-stylelint --files="$STYLE_CHANGED_FILES"; then
            LINT_STATUS=1
        fi
    else
        echo "✅ Skipping CSS lint"
    fi

    if [ -n "${TWIG_CHANGED_FILES:-}" ]; then
        echo "➡ Twig Linting..."
        echo "$TWIG_CHANGED_FILES" | tr ' ' '\n'
        if ! .ddev/commands/web/dev-twigcs --files="$TWIG_CHANGED_FILES"; then
            LINT_STATUS=1
        fi
    else
        echo "✅ Skipping Twig lint"
    fi

    if [ -n "${TEXT_CHANGED_FILES:-}" ]; then
        echo "➡ Spell Checking..."
        echo "$TEXT_CHANGED_FILES" | tr ' ' '\n'
        if ! .ddev/commands/web/dev-cspell --files="$TEXT_CHANGED_FILES"; then
            LINT_STATUS=1
        fi
    else
        echo "✅ Skipping spell check"
    fi
else
    echo "🖥 Running locally"

    # Parse command line arguments
    if [ "$#" -gt 0 ]; then
        case "$1" in
            --all)
                echo "🔍 Checking all files..."
                ARGS="--all"
                ;;
            *)
                echo "❌ Unknown option: $1"
                echo "Usage: ddev dev-lint [--all]"
                exit 1
                ;;
        esac
    else
        echo "🔍 Using git diff..."
        ARGS=""
    fi

    # Run each tool with the same arguments
    echo "➡ PHP Linting..."
    if ! .ddev/commands/web/dev-phpcs $ARGS; then
        LINT_STATUS=1
    fi

    echo "➡ PHP Static Analysis..."
    if ! .ddev/commands/web/dev-phpstan $ARGS; then
        LINT_STATUS=1
    fi

    #echo "➡ Drupal Security PHPCS..."
    #if ! .ddev/commands/web/dev-phpcs-security $ARGS; then
    #    LINT_STATUS=1
    #fi

    echo "➡ JS Linting..."
    if ! .ddev/commands/web/dev-eslint $ARGS; then
        LINT_STATUS=1
    fi

    echo "➡ CSS Linting..."
    if ! .ddev/commands/web/dev-stylelint $ARGS; then
        LINT_STATUS=1
    fi

    echo "➡ Twig Linting..."
    if ! .ddev/commands/web/dev-twigcs $ARGS; then
        LINT_STATUS=1
    fi

    echo "➡ Spell Checking..."
    if ! .ddev/commands/web/dev-cspell $ARGS; then
        LINT_STATUS=1
    fi
fi

if [ $LINT_STATUS -eq 0 ]; then
    echo "✅ All linting completed successfully!"
    exit 0
else
    echo "❌ Some linting checks failed"
    exit 1
fi
