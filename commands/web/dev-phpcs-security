#!/bin/bash

source "${0%/*}/dev-utils.sh"

## #ddev-generated
## Description: Run DrupalSecurity PHPCS checks on custom code and config
# Usage: ddev dev-phpcs-security [--all] [--files=file1.php,file2.yml]
# Example: "ddev dev-phpcs-security" (checks git diff)
#          "ddev dev-phpcs-security --all" (checks all matching files)
#          "ddev dev-phpcs-security --files=file1.php,config/sync/site.yml" (checks specific files)

set -euo pipefail

DEFAULT_EXTENSIONS=("php" "module" "inc" "install" "theme" "yml" "yaml" "twig")
EXTENSIONS=()

# Parse arguments for extensions.
while [[ $# -gt 0 ]]; do
    case "$1" in
        --ext=*)
            IFS=',' read -r -a EXTENSIONS <<< "${1#--ext=}"
            shift
            ;;
        *)
            break
            ;;
    esac
done

if [ ${#EXTENSIONS[@]} -eq 0 ]; then
    EXTENSIONS=("${DEFAULT_EXTENSIONS[@]}")
fi

get_security_changed_files() {
    local extensions=("$@")
    local ext_pattern
    ext_pattern=$(IFS='|'; echo "${extensions[*]}")
    local docroot
    docroot=$(get_docroot)
    local custom_path_pattern="^${docroot}/(modules|themes)/custom/.*\.(${ext_pattern})$"
    local config_path_pattern="^config/.*\.(${ext_pattern})$"

    if [ "${IS_CI:-false}" = "TRUE" ]; then
        git diff --name-only "origin/$BITBUCKET_PR_DESTINATION_BRANCH...$BITBUCKET_BRANCH" 2>/dev/null |
            grep -E "${custom_path_pattern}|${config_path_pattern}" |
            grep -v "node_modules" |
            sort -u | tr '\n' ' '
    else
        {
            git diff --name-only 2>/dev/null
            git diff --name-only --staged 2>/dev/null
        } |
            grep -E "${custom_path_pattern}|${config_path_pattern}" |
            grep -v "node_modules" |
            sort -u | tr '\n' ' '
    fi
}

get_security_all_files() {
    local extensions=("$@")
    local ext_pattern
    ext_pattern=$(IFS='|'; echo "${extensions[*]}")
    local docroot
    docroot=$(get_docroot)

    {
        find "${docroot}/modules/custom" "${docroot}/themes/custom" -type f \
            -regextype posix-extended \
            -regex ".*\.(${ext_pattern})$" \
            -not -path "*/node_modules/*"
        find config -type f \
            -regextype posix-extended \
            -regex ".*\.(${ext_pattern})$"
    } 2>/dev/null | sort -u | tr '\n' ' '
}

get_security_files() {
    local extensions=("$@")
    local i=0
    while [ "$#" -gt 0 ] && [ "${1:0:2}" != "--" ]; do
        extensions[$i]="$1"
        i=$((i + 1))
        shift
    done

    local ext_pattern
    ext_pattern=$(IFS='|'; echo "${extensions[*]}")
    local files=""

    if [ "$#" -eq 0 ]; then
        >&2 echo "🔄 Checking git diff files for security lint..."
        files=$(get_security_changed_files "${extensions[@]}")
    else
        case "$1" in
            --all)
                >&2 echo "🔍 Checking all custom and config files with extensions: ${extensions[*]}"
                files=$(get_security_all_files "${extensions[@]}")
                ;;
            --files=*)
                local specified_files=${1#--files=}
                >&2 echo "🔍 Checking specified files for security lint..."
                files=$(echo "$specified_files" | tr ',' '\n' | \
                    while IFS= read -r file; do
                        if [ -f "$file" ] && echo "$file" | grep -q -E "\.(${ext_pattern})$"; then
                            echo "$file"
                        fi
                    done | sort -u | tr '\n' ' ')
                ;;
            *)
                >&2 echo "❌ Unknown option: $1"
                >&2 echo "Usage: ddev dev-phpcs-security [--all | --files=file1,file2]"
                return 1
                ;;
        esac
    fi

    if [ -z "${files// /}" ]; then
        >&2 echo "🚫 No matching files found"
        return 0
    fi

    echo "$files"
}

if [ $# -eq 0 ]; then
    FILES=$(get_security_files "${EXTENSIONS[@]}")
else
    FILES=$(get_security_files "${EXTENSIONS[@]}" "$@")
fi

if [ -z "${FILES:-}" ]; then
    echo "✅ No files to check"
    exit 0
fi

echo "Files to check:"
echo "$FILES" | tr ' ' '\n'

check_command_executable "$(command -v phpcs 2>/dev/null || echo '/var/www/html/bin/phpcs')" "phpcs"

phpcs -- -s --colors --standard=DrupalSecurity --extensions=php,module,inc,install,theme,yml,yaml,twig --report-full --report-summary $FILES
